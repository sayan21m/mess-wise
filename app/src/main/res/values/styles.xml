<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.MessWise.IndicatorShape" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="App.CustomIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/dark_primary_dim</item>
        <item name="marginHorizontal">12dp</item>
    </style>

    <style name="CustomDatePickerTheme"
        parent="ThemeOverlay.Material3.MaterialCalendar">

        <item name="colorSurface">#000000</item>
        <item name="colorOnSurface">#0B91A2</item>

        <item name="colorPrimary">#00BFA5</item>
        <item name="colorOnPrimary">#0B91A2</item>

        <item name="materialCalendarStyle">
            @style/MessWiseCalendarStyle
        </item>

    </style>

    <style name="MessWiseCalendarStyle"
        parent="Widget.Material3.MaterialCalendar">

        <item name="backgroundTint">#000000</item>

    </style>

</resources>