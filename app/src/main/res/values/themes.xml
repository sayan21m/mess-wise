<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.MessWise" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mw_primary</item>
        <item name="android:windowBackground">@color/mw_bg</item>
    </style>

    <style name="Theme.MessWise" parent="Base.Theme.MessWise" />

    <style name="Base.Theme.MessWise.Dark" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_muted</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>
        <item name="colorError">@color/dark_error</item>
        <item name="colorControlHighlight">#1A52A3B0</item>
        <item name="boxStrokeColor">@color/dark_primary</item>
    </style>

    <style name="Theme.MessWise.Dark" parent="Base.Theme.MessWise.Dark" />

    <style name="NavIndicatorStyle">
        <item name="android:width">64dp</item>
        <item name="android:height">36dp</item>
        <item name="shapeAppearance">
            @style/NavIndicatorShape
        </item>
        <item name="android:color">
            @color/nav_indicator
        </item>
    </style>

    <style name="NavIndicatorShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
        <item name="strokeColor">#ffffff</item>
        <item name="strokeWidth">0.5dp</item>
    </style>

</resources>