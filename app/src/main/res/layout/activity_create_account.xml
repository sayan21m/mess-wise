<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingBottom="80dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/dark_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <View
                    android:layout_width="48dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:background="@color/dark_primary_soft" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE ACCOUNT"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_primary"
                    android:letterSpacing="0.16"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set up a new manager profile"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:letterSpacing="-0.04"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose admin or member setup and complete the details below."
                    android:textSize="13sp"
                    android:textColor="@color/dark_text_muted"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="22dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="22dp"
                    android:background="@color/dark_surface_2"
                    android:padding="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/typeAdmin"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Admin"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:cornerRadius="10dp"
                        app:backgroundTint="@color/dark_primary"
                        app:elevation="0dp"
                        app:rippleColor="#33FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/typeMember"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Member"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@color/dark_text_muted"
                        app:cornerRadius="10dp"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:elevation="0dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="@color/dark_input_bg"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="@color/dark_icon"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etManagerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter full name"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="14sp"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@id/etManagerMail"
                        android:background="#1F1C1C"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mail"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="@color/dark_input_bg"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/dark_icon"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etManagerMail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="abc@mail.com"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@id/etMessName"
                        android:background="#1F1C1C"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/messNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mess Name"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="@color/dark_input_bg"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/dark_icon"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMessName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Chatra Niwas"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@id/etCreatePassword"
                        android:background="#1F1C1C"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="@color/dark_input_bg"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/dark_icon"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/dark_icon"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCreatePassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Create a strong password"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@id/etConfirmPassword"
                        android:background="#1F1C1C"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_text_primary"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxBackgroundColor="@color/dark_input_bg"
                    app:boxStrokeColor="@color/input_stroke_selector"
                    app:boxStrokeWidth="1dp"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/dark_icon"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/dark_icon"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Re-enter password"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:background="#1F1C1C"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <CheckBox
                        android:id="@+id/cbAgree"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:buttonTint="@color/dark_primary"
                        android:text="I agree to the terms and privacy policy"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateAccount"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Create Account"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/dark_primary"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    app:rippleColor="#33FFFFFF"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconGravity="textEnd"
                    app:iconTint="@color/white"
                    app:iconSize="18dp" />

                <TextView
                    android:id="@+id/loginActivity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:text="Already have an account? Log in"
                    android:textSize="13sp"
                    android:textColor="@color/dark_text_faint"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>