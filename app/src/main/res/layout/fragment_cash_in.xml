<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".fragment_ui.cash_in.CashInFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <!-- ══════════════════════════════════════
                 TOP HERO SECTION  (tinted bg block)
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_tinted"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="32dp">

                <!-- Page title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:letterSpacing="-0.01"
                    android:text="@string/cash_in_title"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/cash_in_subtitle"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="13sp" />

                <!-- Balance Card — floating over hero -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_balance_card"
                    android:padding="20dp">

                    <!-- Ghost wallet bg -->
                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:alpha="0.07"
                        android:contentDescription="@null"
                        android:src="@drawable/vector_wallet_outline_bg"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Left: wallet illustration -->
                    <FrameLayout
                        android:id="@+id/walletFrame"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/vector_wallet_illustration" />

                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="top|center_horizontal"
                            android:layout_marginTop="-2dp"
                            android:background="@drawable/bg_transaction_icon">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="₹"
                                android:textColor="@color/bg_dark"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </FrameLayout>
                    </FrameLayout>

                    <!-- Right: balance info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/walletFrame"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cash_in_current_balance_label"
                            android:textColor="@color/dark_text_muted"
                            android:textSize="11sp"
                            android:letterSpacing="0.02" />

                        <TextView
                            android:id="@+id/tvWalletBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:letterSpacing="-0.02"
                            android:text="@string/cash_in_sample_balance"
                            android:textColor="@color/dark_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_available_badge"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_check_small"
                                app:tint="@color/dark_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="@string/cash_in_available_balance"
                                android:textColor="@color/dark_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.02" />
                        </LinearLayout>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 AMOUNT SECTION
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="28dp">

                <!-- Section label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="13dp"
                        android:background="@drawable/bg_accent_bar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:letterSpacing="0.1"
                        android:text="@string/cash_in_enter_amount"
                        android:textAllCaps="true"
                        android:textColor="@color/dark_primary"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Amount input row -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_amount_input">

                    <!-- Rupee badge -->
                    <FrameLayout
                        android:id="@+id/rupeeBox"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_rupee_square"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="₹"
                            android:textColor="@color/dark_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <!-- Input -->
                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/cash_in_amount_hint"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="14dp"
                        android:textColor="@color/dark_text_primary"
                        android:textColorHint="@color/dark_text_hint"
                        android:textSize="17sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvAmountPreview"
                        app:layout_constraintStart_toEndOf="@id/rupeeBox"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Live amount display -->
                    <TextView
                        android:id="@+id/tvAmountPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="@string/cash_in_amount_zero"
                        android:textColor="@color/dark_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Quick amount chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip500"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_amount_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/cash_in_chip_500"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip1000"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_amount_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/cash_in_chip_1000"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip2000"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_amount_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/cash_in_chip_2000"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip5000"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_amount_chip"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/cash_in_chip_5000"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 RECENT TRANSACTIONS SECTION
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="30dp">

                <!-- Section header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="13dp"
                        android:background="@drawable/bg_accent_bar" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:layout_weight="1"
                        android:letterSpacing="0.1"
                        android:text="@string/cash_in_recent"
                        android:textAllCaps="true"
                        android:textColor="@color/dark_primary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/btnViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="2dp"
                        android:paddingVertical="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cash_in_view_all"
                            android:textColor="@color/dark_primary"
                            android:textSize="12sp" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="2dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/dark_primary" />
                    </LinearLayout>
                </LinearLayout>

                <!-- List / empty state card -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="70dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_dark"
                        android:clipToPadding="false"
                        android:padding="10dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingVertical="6dp"
                        tools:itemCount="5"
                        tools:listitem="@layout/item_transaction" />

                    <!-- Empty state -->
                    <LinearLayout
                        android:id="@+id/layoutEmptyTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_dark"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="40dp"
                        android:paddingBottom="40dp"
                        android:visibility="gone">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_empty_icon_circle">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:alpha="0.5"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_receipt"
                                app:tint="@color/dark_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="No transactions yet"
                            android:textColor="@color/dark_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.4"
                            android:text="Your recent cash in history\nwill appear here"
                            android:textColor="@color/dark_text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════
         BOTTOM STICKY BUTTON  (elevated card)
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/cardAddMoney"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddMoney"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/cash_in_add_money"
            android:textAllCaps="false"
            android:textColor="@color/bg_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/dark_primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_add_money"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            app:iconTint="@color/bg_dark"
            app:rippleColor="#33000000" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>