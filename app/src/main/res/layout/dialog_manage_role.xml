<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_dark"
    app:cardCornerRadius="32dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="#1E293B"
            android:padding="16dp"
            android:src="@drawable/ic_admin"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:tint="@color/nav_selected" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Assign Role"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Set a specific position for this member"
            android:textColor="@color/dark_text_muted"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/rgRoles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <RadioButton
                android:id="@+id/rbAdmin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Admin"
                android:textColor="@color/white"
                android:buttonTint="@color/nav_selected" />

            <RadioButton
                android:id="@+id/rbMealManager"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Meal Manager"
                android:textColor="@color/white"
                android:buttonTint="@color/nav_selected" />

            <RadioButton
                android:id="@+id/rbMember"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Normal Member"
                android:textColor="@color/white"
                android:buttonTint="@color/nav_selected" />

            <RadioButton
                android:id="@+id/rbCustom"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Custom Position"
                android:textColor="@color/white"
                android:buttonTint="@color/nav_selected" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCustomRole"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:boxBackgroundColor="#111111"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/nav_selected"
            app:hintTextColor="@color/nav_selected"
            android:hint="Role Name (e.g. Secretary)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/white"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/dark_text_muted"
                android:textAllCaps="false"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveRole"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_weight="1.2"
                android:text="Save Role"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:backgroundTint="@color/white"
                app:cornerRadius="16dp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
