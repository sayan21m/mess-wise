<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_dark"
    app:cardCornerRadius="36dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="24dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivSummaryIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="#1E2A2E"
                android:padding="14dp"
                android:src="@drawable/ic_summary"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:tint="@color/teal_accent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivSummaryIcon"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meal Summary"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSummaryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="26 Jun 2026"
                    android:textColor="@color/teal_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnCloseSummary"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_close"
                android:padding="6dp"
                app:tint="#444444" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/btnShowTaking"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_amount_input"
                android:padding="16dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalTakingMeal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAKING"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="12dp" android:layout_height="1dp"/>

            <LinearLayout
                android:id="@+id/btnShowLeave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_amount_input"
                android:padding="16dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalOnLeave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/dark_error"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ON LEAVE"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_gravity="start"
            android:text="MEMBERS ON LEAVE"
            android:textColor="@color/dark_text_muted"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1A1A1A">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeavesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:maxHeight="180dp" />

            <LinearLayout
                android:id="@+id/dialogEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_check_small"
                    app:tint="@color/dark_success" />

                <TextView
                    android:id="@+id/tvEmptyMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Full house today!"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearNotifications"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="Clear Notifications"
            android:textAllCaps="false"
            android:textColor="@color/dark_error"
            app:backgroundTint="#1A1212"
            app:cornerRadius="18dp"
            android:textStyle="bold"
            app:rippleColor="#20FF0000"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
