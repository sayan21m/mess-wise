<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    tools:context=".admin_ui.MealAdminActivity">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/card_background"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEAL MANAGEMENT"
            android:textColor="@color/dark_text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meal Count"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

        <ImageButton
            android:id="@+id/btnStats"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/card_background"
            android:src="@drawable/bar_chart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/teal_accent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Input Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Member Selection -->
                <TextView
                    android:id="@+id/labelMember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Member"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/spinnerMemberLayout"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/card_background"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintEnd_toStartOf="@id/layoutMealsInput"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelMember"
                    app:layout_constraintHorizontal_weight="0.6">

                    <ImageView
                        android:id="@+id/iconMember"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/teal_accent" />

                    <Spinner
                        android:id="@+id/spinnerMember"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:dropDownVerticalOffset="52dp"
                        app:layout_constraintEnd_toStartOf="@id/arrowMember"
                        app:layout_constraintStart_toEndOf="@id/iconMember" />

                    <ImageView
                        android:id="@+id/arrowMember"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:rotation="90"
                        android:src="@drawable/ic_chevron_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/dark_text_muted" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Meals Count Selection -->
                <TextView
                    android:id="@+id/labelMeals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meals"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="@id/layoutMealsInput"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutMealsInput"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_background"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/spinnerMemberLayout"
                    app:layout_constraintTop_toBottomOf="@id/labelMeals"
                    app:layout_constraintHorizontal_weight="0.4">

                    <ImageView
                        android:id="@+id/iconMeal"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_meal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#4CAF50" />

                    <EditText
                        android:id="@+id/etMeals"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:background="@android:color/transparent"
                        android:hint="1"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:textColorHint="@color/dark_text_muted"
                        android:textSize="14sp"
                        android:imeOptions="actionNext"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iconMeal" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Date Picker -->
                <TextView
                    android:id="@+id/labelDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Date"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/spinnerMemberLayout" />

                <LinearLayout
                    android:id="@+id/btnDate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintTop_toBottomOf="@id/labelDate">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_summary"
                        app:tint="@color/teal_accent" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Select Date"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_summary"
                        app:tint="@color/dark_text_muted" />
                </LinearLayout>

                <!-- Note Field -->
                <TextView
                    android:id="@+id/labelNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Note (Optional)"
                    android:textColor="@color/dark_text_muted"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnDate" />

                <LinearLayout
                    android:id="@+id/layoutNote"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintTop_toBottomOf="@id/labelNote">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_terms"
                        app:tint="@color/teal_accent" />

                    <EditText
                        android:id="@+id/etNote"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="Lunch + Dinner"
                        android:textColor="@color/white"
                        android:textColorHint="@color/dark_text_muted"
                        android:textSize="14sp"
                        android:imeOptions="actionDone"
                        android:inputType="text" />
                </LinearLayout>

                <!-- Action Buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetMeal"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="SET MEAL COUNT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_summary"
                    app:iconGravity="textStart"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_btn_teal_gradient"
                    app:layout_constraintTop_toBottomOf="@id/layoutNote" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkPresent"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="MARK PRESENT (+1 MEAL)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_profile"
                    app:iconGravity="textStart"
                    app:backgroundTint="#2E7D32"
                    app:layout_constraintTop_toBottomOf="@id/btnSetMeal" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/card_background"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconMonth"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_profile_circle"
                        android:backgroundTint="#1A6200EE"
                        android:padding="8dp"
                        android:src="@drawable/ic_meal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#7C4DFF" />

                    <TextView
                        android:id="@+id/labelCurrentMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="CURRENT MONTH"
                        android:textColor="@color/teal_accent"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconMonth"
                        app:layout_constraintTop_toTopOf="@id/iconMonth" />

                    <TextView
                        android:id="@+id/tvMealsTaken"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="156"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconMonth"
                        app:layout_constraintTop_toBottomOf="@id/labelCurrentMonth"
                        android:layout_marginStart="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/mt1"
                        android:text="Meals Taken"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="@id/tvMealsTaken"
                        app:layout_constraintTop_toBottomOf="@id/tvMealsTaken"
                        />

                    <TextView
                        android:id="@+id/show_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/card_background"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="June 2025"
                        android:textColor="@color/teal_accent"
                        android:textSize="10sp"
                        app:drawableStartCompat="@drawable/ic_summary"
                        app:drawableTint="@color/teal_accent"
                        app:layout_constraintTop_toBottomOf="@id/mt1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:drawablePadding="6dp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_background"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/iconMembers"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_profile_circle"
                        android:backgroundTint="#1A2E7D32"
                        android:padding="8dp"
                        android:src="@drawable/ic_group"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#4CAF50" />

                    <TextView
                        android:id="@+id/labelActiveMembers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ACTIVE MEMBERS"
                        android:textColor="#4CAF50"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconMembers"
                        app:layout_constraintTop_toTopOf="@id/iconMembers" />

                    <TextView
                        android:id="@+id/tvParticipating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconMembers"
                        app:layout_constraintTop_toBottomOf="@id/labelActiveMembers"
                        android:layout_marginStart="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/mt2"
                        android:text="Participating"
                        android:textColor="@color/dark_text_muted"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="@id/tvParticipating"
                        app:layout_constraintTop_toBottomOf="@id/tvParticipating" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/card_background"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="48 Entries"
                        android:textColor="#4CAF50"
                        android:textSize="10sp"
                        app:drawableStartCompat="@drawable/ic_summary"
                        app:drawableTint="#4CAF50"
                        app:layout_constraintTop_toBottomOf="@id/mt2"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:drawablePadding="6dp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <!-- Distribution Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/card_background"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iconDistribution"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_summary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#7C4DFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Meal Distribution"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/iconDistribution"
                    app:layout_constraintStart_toEndOf="@id/iconDistribution"
                    app:layout_constraintTop_toTopOf="@id/iconDistribution" />

                <LinearLayout
                    android:id="@+id/distributionList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/iconDistribution">

                    <!-- Member Row Template -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Sayan"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:progress="80"
                            android:progressTint="#7C4DFF"
                            android:progressBackgroundTint="@color/dark_border"/>
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="24"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Rahul"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:progress="60"
                            android:progressTint="@color/teal_accent"
                            android:progressBackgroundTint="@color/dark_border"/>
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="18"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Ankit"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:progress="40"
                            android:progressTint="#4F8CFF"
                            android:progressBackgroundTint="@color/dark_border"/>
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Priya"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:progress="70"
                            android:progressTint="#4CAF50"
                            android:progressBackgroundTint="@color/dark_border"/>
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="21"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Tushar"
                            android:textColor="@color/white"
                            android:textSize="13sp" />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="12dp"
                            android:progress="30"
                            android:progressTint="#FF7043"
                            android:progressBackgroundTint="@color/dark_border"/>
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="9"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:gravity="end" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/btnDetailedReport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="8dp"
                    android:text="VIEW DETAILED REPORT"
                    android:textColor="@color/teal_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:drawableEndCompat="@drawable/ic_chevron_right"
                    app:drawableTint="@color/teal_accent"
                    android:drawablePadding="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/distributionList" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
